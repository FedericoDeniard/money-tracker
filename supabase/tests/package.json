{
  "name": "supabase-functions-tests",
  "version": "1.0.0", 
  "description": "Local testing suite for Supabase Edge Functions",
  "type": "module",
  "scripts": {
    "test": "deno test --allow-all",
    "test:auth": "deno test --allow-all tests/auth-*.test.ts",
    "test:processing": "deno test --allow-all tests/seed-emails.test.ts tests/gmail-webhook.test.ts",
    "test:shared": "deno test --allow-all tests/shared/*.test.ts",
    "test:coverage": "deno test --allow-all --coverage tests/"
  },
  "devDependencies": {
    "@types/deno": "^2.1.0"
  },
  "imports": {
    "test-utils": "./helpers/test-utils.ts",
    "mock-data": "./helpers/mock-data.ts", 
    "supabase-mock": "./helpers/supabase-mock.ts"
  }
}