# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
FRONTEND_URL=http://localhost:3000

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
GOOGLE_PROJECT_ID=your_google_project_id
PUBSUB_TOPIC=gmail-notifications

# AI Configuration
XAI_API_KEY=your_xai_api_key_here
# XAI_MODEL overrides the primary xAI model (default: grok-4.20-non-reasoning-latest)
# XAI_MODEL=grok-4.20-non-reasoning-latest
# XAI_FILE_FALLBACK_MODEL overrides the PDF fallback model (default: grok-4.20-reasoning-latest)
# XAI_FILE_FALLBACK_MODEL=grok-4.20-reasoning-latest

# Langfuse Configuration
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=false

INTERNAL_FUNCTIONS_SECRET=local-dev-internal-secret
# ─── Supabase Vault secrets (production) ─────────────────────────────────────
# INTERNAL_FUNCTIONS_SECRET must also exist in Supabase Vault so SQL triggers
# can read it to authenticate internal edge function calls.
# Run once in the Supabase SQL Editor (production):
#
#   SELECT vault.create_secret('<your-secret>', 'INTERNAL_FUNCTIONS_SECRET');
#
# The local DB seed already inserts it automatically via supabase/seed.sql.

# ─── OAuth token encryption key (production) ─────────────────────────────────
# TOKEN_ENCRYPTION_KEY must exist in Supabase Vault so the encrypt_secret /
# decrypt_secret RPCs can read it. Generate with:
#   openssl rand -hex 32
# Then run once in the Supabase SQL Editor (production):
#
#   SELECT vault.create_secret('<hex-32-bytes>', 'TOKEN_ENCRYPTION_KEY');
#
# The local DB seed already inserts a placeholder automatically via
# supabase/seeds/006_token_encryption_key_local.sql. Rotate via a future
# migration that re-encrypts *_encrypted columns with the new key.
# DO NOT log this key in any edge function output.

# Web Push (VAPID) keys — generate with: npx web-push generate-vapid-keys
# These are read by the send-push-notification edge function via Deno.env.
# In production, set them as Supabase Edge Function Secrets:
#   Supabase Dashboard → Project Settings → Edge Functions → Secrets
#   Add: VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_EMAIL
#
# VAPID_PUBLIC_KEY must also be set in the Railway frontend env as VAPID_PUBLIC_KEY
# (it is exposed to the browser via /api/config — safe to expose).
#
# Additionally, the SQL trigger (dispatch_push_notification) reads SUPABASE_URL
# from Vault to build the edge function URL. Add it once in the SQL Editor:
#
#   SELECT vault.create_secret('https://<your-project-ref>.supabase.co', 'SUPABASE_URL');
#
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:fededeniard@gmail.com

# Optional runtime metadata
ENVIRONMENT=development

# Note: No BACKEND_URL needed - using Supabase Edge Functions
# All API calls go to: ${SUPABASE_URL}/functions/v1

# Billing providers (provider-agnostic; keys are per-provider)
# ─────────────────────────────────────────────────────────────────────────────
# Mercado Pago (subscriptions / preapproval). Get these from
#   https://www.mercadopago.com.ar/developers/panel/app
#   → Your app → Credentials (test or production)
# Test credentials start with APP_USR- and are safe to commit; production ones are not.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# Webhook secret comes from:
#   Tus Integraciones → Your app → Webhooks → Configurar notificaciones
# Save the secret after clicking "Guardar" (you can reset it later).
MP_WEBHOOK_SECRET=
# test | production — controls whether invalid signatures are accepted for debugging
MP_ENVIRONMENT=test
# Back URL for the user after checkout (no webhook; this is the browser redirect)
MP_BACK_URL=http://localhost:3000/billing
# MLA (Argentina) | MLM (Mexico) | MLB (Brazil) | MLC (Chile) | MCO (Colombia) | MLU (Uruguay) | MPE (Peru)
MP_SITE_ID=MLA
# Webhook notification URL for subscription events. REQUIRED — subscriptions
# webhooks cannot be configured via the MP developer panel; they must be set
# at payment creation time via notification_url in the POST /preapproval body.
# For local dev, use your cloudflared tunnel URL; for production, use the
# Supabase Edge Functions URL:
#   https://<project-ref>.supabase.co/functions/v1/payments-webhook/mercadopago
MP_NOTIFICATION_URL=
# When adding more providers (e.g. Stripe), replicate the pattern:
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_ENVIRONMENT=test
# ...
