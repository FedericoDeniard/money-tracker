meta {
  name: unknown provider
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/functions/v1/payments-webhook/stripe
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  { "type": "ping" }
