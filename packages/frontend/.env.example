# Supabase Configuration
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Frontend server
PORT=3000

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# The public key is exposed to the browser via /api/config (safe to expose)
# The private key must NEVER be exposed to the browser — store in Supabase Vault in production
VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY is NOT read by the frontend server — it lives only in supabase/functions/.env

# Optional (used by E2E tests)
XAI_API_KEY=