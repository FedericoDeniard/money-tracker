OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_FINANCIAL_AGENT_MODEL overrides the primary chat model (default: google/gemini-2.5-flash-lite)
# Multimodal (text, image, file, audio, video), 1M context, 3-5x faster token generation
# than the previous bytedance-seed/seed-2.0-mini. Same price tier ($0.10/M in, $0.40/M out).
# OPENROUTER_FINANCIAL_AGENT_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_THREAD_TITLE_MODEL overrides the thread title generation model (default: google/gemini-2.5-flash-lite)
# OPENROUTER_THREAD_TITLE_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_GUARDRAIL_MODEL overrides the guardrail classification model (default: google/gemini-2.5-flash-lite)
# Used by the TopicGuardrailProcessor. Text-only inputs are fine because the
# processor only reads text content from messages; image attachments are
# passed through (fail-open) to the main agent.
# OPENROUTER_GUARDRAIL_MODEL=google/gemini-2.5-flash-lite
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
MASTRA_PORT=4111
# Comma-separated list of allowed origins
MASTRA_CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000
