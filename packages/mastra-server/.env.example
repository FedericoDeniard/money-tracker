OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_FINANCIAL_AGENT_MODEL overrides the primary chat model (default: bytedance-seed/seed-2.0-mini)
# Multimodal (text, image, video), designed for latency-sensitive, cost-sensitive workloads.
# Same price tier as the previous gemma-4-31b-it default.
# OPENROUTER_FINANCIAL_AGENT_MODEL=bytedance-seed/seed-2.0-mini
# OPENROUTER_THREAD_TITLE_MODEL overrides the thread title generation model (default: google/gemini-2.5-flash-lite)
# OPENROUTER_THREAD_TITLE_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_GUARDRAIL_MODEL overrides the guardrail classification model (default: deepseek/deepseek-v4-flash)
# Used by both PromptInjectionDetector and TopicGuardrailProcessor. Text-only models
# are fine here because both processors only read text content from messages; image
# attachments are passed through (fail-open) to the main agent.
# OPENROUTER_GUARDRAIL_MODEL=deepseek/deepseek-v4-flash
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
MASTRA_PORT=4111
# Comma-separated list of allowed origins
MASTRA_CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000
