# =============================================================================
# AI providers
# =============================================================================

# OpenRouter — used by the financial chat agent and the topic guardrail
OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_FINANCIAL_AGENT_MODEL (default: google/gemini-2.5-flash-lite)
# OPENROUTER_THREAD_TITLE_MODEL (default: google/gemini-2.5-flash-lite)
# OPENROUTER_GUARDRAIL_MODEL (default: google/gemini-2.5-flash-lite)

# xAI (Grok) — used by the seed-emails pipeline (transaction extraction)
# XAI_MODEL (default: grok-4.20-non-reasoning-latest)
# XAI_FILE_FALLBACK_MODEL (default: grok-4.20-reasoning-latest)
XAI_API_KEY=xai-...

# Langfuse — LLM observability traces
# Get keys from https://langfuse.com → Settings → API Keys
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# =============================================================================
# Supabase
# =============================================================================
# Get these from your Supabase project: Settings → API

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Direct Postgres connection for Mastra storage (libsql/pg format)
# Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# =============================================================================
# Google OAuth — Gmail flows
# =============================================================================
# Get from Google Cloud Console → APIs & Services → Credentials

GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Must match an authorized redirect URI in your OAuth client config
OAUTH_REDIRECT_URI=http://127.0.0.1:54321/functions/v1/auth-callback

# =============================================================================
# Server config
# =============================================================================

MASTRA_PORT=4111
# Comma-separated list of origins allowed by CORS (frontend URLs)
MASTRA_CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000

# Comma-separated list of origins for the shared supabase/functions code CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SimpleAuth token for Studio login (CompositeAuth with Supabase)
STUDIO_DEV_TOKEN=dev-token

# Must match INTERNAL_FUNCTIONS_SECRET in Supabase vault for SQL triggers
INTERNAL_FUNCTIONS_SECRET=local-dev-internal-secret
