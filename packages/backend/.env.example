# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_PROJECT_ID=your_google_project_id_here

# OAuth Redirect URI
OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback

# Pub/Sub Configuration
PUBSUB_TOPIC=gmail-notifications
PUBSUB_SUBSCRIPTION=gmail-sub

# Supabase Configuration
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Encryption Key for OAuth tokens (use a strong random string)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_encryption_key_here_use_openssl_rand_base64_32

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:3000